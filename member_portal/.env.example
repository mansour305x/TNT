# ═══════════════════════════════════════════════════════════
# TNT Alliance Portal Configuration
# ═══════════════════════════════════════════════════════════

# ── قاعدة البيانات ──
PORTAL_DB_PATH=/tmp/portal.db
PORTAL_SECRET_KEY=your-super-secret-key-change-this-in-production

# ── حساب المالك الرئيسي ──
OWNER_USERNAME=DANGER
OWNER_PASSWORD=Aa@123456

# ── OAuth2 - Google ──
# الحصول على هذه المفاتيح من: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# ── OAuth2 - Discord (اختياري للمستقبل) ──
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# ── إعدادات البريد الإلكتروني (Gmail SMTP) ──
# ملاحظة: استخدم "App Password" من Google بدلاً من كلمة المرور العادية
# https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME=TNT Alliance

# ── بيئة التطوير ──
# قيم: development, production, testing
ENVIRONMENT=development

# ── التسجيل ──
LOG_LEVEL=INFO
LOG_FILE=/tmp/portal.log

# ── Render (إذا كنت تنشر على Render) ──
RENDER=false
