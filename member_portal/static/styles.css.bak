:root {
  --bg: #f4f7fc;
  --card: #ffffff;
  --ink: #16263f;
  --muted: #667891;
  --line: #d9e3f2;
  --primary: #1f6dff;
  --primary-2: #3f8bff;
  --danger: #c53f39;
  --shadow: 0 14px 35px rgba(15, 38, 74, 0.08);
}

:root[data-theme="dark"] {
  --bg: #101723;
  --card: #172233;
  --ink: #e8f0ff;
  --muted: #9db0cf;
  --line: #2a3c59;
  --primary: #5b9bff;
  --primary-2: #77b3ff;
  --danger: #e56d68;
  --shadow: 0 16px 30px rgba(0, 0, 0, 0.34);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  color: var(--ink);
  background: var(--bg);
  font-family: "Segoe UI", Tahoma, sans-serif;
}

.page-bg {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background: radial-gradient(circle at 8% 10%, rgba(31, 109, 255, 0.16), transparent 32%),
    radial-gradient(circle at 90% 0%, rgba(86, 175, 255, 0.2), transparent 28%);
}

.topbar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 4vw;
  background: color-mix(in srgb, var(--card) 86%, transparent);
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(8px);
  position: sticky;
  top: 0;
  z-index: 10;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  color: var(--ink);
}

.brand-badge {
  height: 42px;
  min-width: 42px;
  border-radius: 12px;
  display: grid;
  place-items: center;
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  font-weight: 800;
  font-size: 0.82rem;
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-text strong {
  font-size: 1.02rem;
}

.brand-text small {
  color: var(--muted);
  font-size: 0.75rem;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.nav-links a {
  text-decoration: none;
  color: var(--ink);
  border: 1px solid transparent;
  border-radius: 10px;
  padding: 7px 12px;
  font-weight: 700;
}

.nav-links a:hover {
  background: color-mix(in srgb, var(--primary) 14%, transparent);
  border-color: color-mix(in srgb, var(--primary) 36%, transparent);
}

.user-chip {
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--card);
  padding: 6px 10px;
  font-size: 0.85rem;
}

.profile-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  text-decoration: none;
  color: var(--ink);
}

.profile-chip small {
  color: var(--muted);
  font-size: 0.72rem;
}

.lang-form {
  display: flex;
  align-items: center;
  gap: 6px;
  border: 1px solid var(--line);
  background: var(--card);
  border-radius: 10px;
  padding: 4px;
}

.lang-form select {
  border: 1px solid #cfdbef;
  border-radius: 8px;
  background: var(--card);
  color: var(--ink);
  height: 34px;
  padding: 0 8px;
}

.container {
  width: min(1120px, 94vw);
  margin: 20px auto 36px;
}

.hero-card {
  background: linear-gradient(120deg, #114396 0%, #1f6dff 60%, #4cb5ff 100%);
  border-radius: 18px;
  color: #fff;
  padding: 24px;
  box-shadow: var(--shadow);
  margin-bottom: 16px;
}

.hero-royal {
  background:
    radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.32), transparent 30%),
    linear-gradient(130deg, #071f46 0%, #114396 45%, #2578ff 100%);
  border: 1px solid rgba(255, 255, 255, 0.22);
  box-shadow: 0 22px 48px rgba(5, 17, 47, 0.45);
}

.hero-card h1 {
  margin: 0;
}

.hero-card p {
  margin: 8px 0 0;
  color: rgba(255, 255, 255, 0.92);
}

.layout,
.auth-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.layout {
  grid-template-columns: 1.1fr 0.9fr;
}

.panel {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 18px;
  box-shadow: var(--shadow);
}

.panel h2 {
  margin-top: 0;
  font-size: 1.15rem;
}

.stacked {
  display: grid;
  gap: 12px;
}

.member-form-strip-wrap {
  display: grid;
  gap: 14px;
}

.member-form-strip {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(210px, 210px);
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 8px;
}

.strip-field {
  min-width: 0;
}

.strip-field-notes {
  min-width: 280px;
}

.member-form-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

label {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

label span {
  color: var(--muted);
  font-size: 0.88rem;
  font-weight: 700;
}

input,
select {
  width: 100%;
  border: 1px solid #cdd9ee;
  border-radius: 10px;
  height: 42px;
  padding: 0 12px;
  background: var(--card);
  color: var(--ink);
}

textarea {
  width: 100%;
  border: 1px solid #cdd9ee;
  border-radius: 10px;
  padding: 10px 12px;
  background: var(--card);
  color: var(--ink);
  resize: vertical;
  min-height: 96px;
  font: inherit;
}

input:focus,
select:focus,
textarea:focus {
  outline: none;
  border-color: #6ea4ff;
  box-shadow: 0 0 0 3px rgba(39, 122, 255, 0.15);
}

.field-block {
  border: 1px solid #e1e9f7;
  border-radius: 12px;
  padding: 10px;
  background: color-mix(in srgb, var(--card) 90%, #f9fbff);
  align-self: start;
}

.inline-add {
  margin-top: 8px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
}

.inline-selection-cell {
  white-space: nowrap;
}

.inline-selection-item {
  display: inline-flex;
  align-items: center;
  margin-inline-end: 6px;
  margin-bottom: 4px;
}

.hidden-submit-form {
  display: none;
}

.btn {
  border: 1px solid #cad9f4;
  border-radius: 10px;
  background: color-mix(in srgb, var(--card) 88%, #f4f8ff);
  color: var(--ink);
  height: 40px;
  padding: 0 12px;
  cursor: pointer;
  font-weight: 700;
}

.btn-primary {
  border: 0;
  color: #fff;
  background: linear-gradient(120deg, var(--primary), var(--primary-2));
}

.btn-ghost {
  background: var(--card);
}

.btn-danger {
  border: 0;
  background: var(--danger);
  color: #fff;
}

.theme-toggle {
  min-width: 84px;
}

.table-wrap {
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
  min-width: 620px;
}

th,
td {
  padding: 10px 8px;
  border-bottom: 1px solid var(--line);
  vertical-align: top;
  text-align: start;
}

th {
  background: color-mix(in srgb, var(--card) 70%, #e8f1ff);
}

.flash {
  width: min(1120px, 94vw);
  margin: 14px auto 0;
  border-radius: 12px;
  padding: 10px 12px;
  border: 1px solid;
  font-weight: 700;
}

.flash-info {
  background: #eaf3ff;
  border-color: #bfd6ff;
}

.flash-success {
  background: #e6f8ef;
  border-color: #91d8af;
}

.flash-error {
  background: #ffe8e6;
  border-color: #e4a3a0;
}

.value-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 3px 10px;
  font-size: 0.82rem;
  font-weight: 800;
  margin-inline-start: 6px;
}

.badge-default {
  background: #eef4ff;
  color: #1f56b5;
}

.badge-active {
  background: #e6f8ef;
  color: #18794e;
}

.badge-inactive,
.badge-t11 {
  background: #ffe7e5;
  color: #b3322d;
}

.badge-t12 {
  background: #fff0d9;
  color: #a95a00;
}

.auth-wrap {
  display: grid;
  gap: 16px;
}

.auth-panel-single {
  width: min(520px, 100%);
}

.register-link-line {
  margin: 14px 0 0;
  color: var(--muted);
  font-size: 0.9rem;
}

.register-link-line a {
  color: var(--primary);
  font-weight: 700;
  text-decoration: none;
}

/* ━━━━━━━━━━━━━━━━  UTILITY  ━━━━━━━━━━━━━━━━ */
.full-btn { width: 100%; justify-content: center; }
.null-val { color: var(--muted); }
.req-star { color: var(--danger); }

/* Override btn to support icon alignment */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

/* ━━━━━━━━━━━━━━━━  THEME TOGGLE  ━━━━━━━━━━━━━━━━ */
.theme-toggle-btn {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: var(--card);
  cursor: pointer;
  display: grid;
  place-items: center;
  font-size: 1rem;
  color: var(--ink);
  flex-shrink: 0;
}
.theme-toggle-btn:hover {
  background: color-mix(in srgb, var(--primary) 10%, var(--card));
}

/* ━━━━━━━━━━━━━━━━  PROFILE DROPDOWN  ━━━━━━━━━━━━━━━━ */
.profile-nav { position: relative; }

.profile-trigger {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 7px 12px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: var(--card);
  cursor: pointer;
  color: var(--ink);
  font-weight: 700;
  font-size: 0.88rem;
  font-family: inherit;
}
.profile-trigger:hover { background: color-mix(in srgb, var(--primary) 10%, var(--card)); }

.profile-avatar-sm {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  color: #fff;
  font-size: 0.8rem;
  font-weight: 900;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.chevron-icon { transition: transform 0.2s; }
.profile-nav.open .chevron-icon { transform: rotate(180deg); }

.profile-trigger-name {
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-dropdown-title {
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--primary);
  margin-bottom: 12px;
}

.profile-dropdown {
  display: none;
  position: absolute;
  top: calc(100% + 8px);
  inset-inline-end: 0;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 16px;
  min-width: 240px;
  box-shadow: var(--shadow);
  z-index: 200;
}
.profile-nav.open .profile-dropdown { display: block; }

.profile-info-block {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.profile-avatar-lg {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  flex-shrink: 0;
  background: linear-gradient(135deg, var(--primary), var(--primary-2));
  color: #fff;
  font-size: 1.4rem;
  font-weight: 900;
  display: grid;
  place-items: center;
}

.profile-info-text { min-width: 0; }
.profile-username { font-weight: 800; font-size: 0.97rem; }
.profile-meta { color: var(--muted); font-size: 0.8rem; margin-top: 2px; }

.settings-grid {
  display: grid;
  gap: 8px;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 9px 10px;
  background: color-mix(in srgb, var(--card) 65%, var(--bg));
}

.setting-row strong {
  text-align: end;
  font-size: 0.84rem;
}

.setting-label {
  color: var(--muted);
  font-size: 0.78rem;
  font-weight: 700;
}

.profile-admin-badge {
  display: inline-block;
  margin-top: 5px;
  background: linear-gradient(120deg, var(--primary), var(--primary-2));
  color: #fff;
  font-size: 0.7rem;
  font-weight: 800;
  padding: 1px 8px;
  border-radius: 999px;
}

.profile-dropdown-footer { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--line); }
.profile-logout { width: 100%; justify-content: center; color: var(--ink); text-decoration: none; }

/* ━━━━━━━━━━━━━━━━  TNT GRAND LOGO  ━━━━━━━━━━━━━━━━ */
.auth-center-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32px 0 48px;
  gap: 24px;
}

.tnt-logo-hero { text-align: center; }

.tnt-logo-outer-ring {
  display: inline-block;
  padding: 6px;
  border-radius: 38px;
  background: linear-gradient(135deg, rgba(31, 109, 255, 0.28), rgba(76, 181, 255, 0.1));
  box-shadow: 0 0 0 1px rgba(31, 109, 255, 0.25), 0 24px 64px rgba(31, 109, 255, 0.22);
  margin: 0 auto 20px;
}

.tnt-logo-badge-xl {
  width: 108px;
  height: 108px;
  border-radius: 30px;
  background: linear-gradient(145deg, #082459 0%, #1557d9 50%, #3ea8ff 100%);
  box-shadow:
    0 10px 32px rgba(31, 109, 255, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.28),
    inset 0 -2px 6px rgba(0, 0, 0, 0.25);
  display: grid;
  place-items: center;
  position: relative;
  overflow: hidden;
}

.tnt-logo-badge-xl::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 35% 28%, rgba(255, 255, 255, 0.38), transparent 55%);
}

.tnt-logo-text {
  font-size: 2.2rem;
  font-weight: 900;
  color: #fff;
  letter-spacing: 0.1em;
  position: relative;
  z-index: 1;
  text-shadow: 0 3px 10px rgba(0, 0, 0, 0.4);
}

.tnt-logo-title {
  font-size: 2.1rem;
  font-weight: 900;
  color: var(--ink);
  margin: 0;
  letter-spacing: -0.025em;
}

.tnt-logo-subtitle {
  color: var(--muted);
  margin: 6px 0 0;
  font-size: 1rem;
}

.tnt-stars {
  color: #f5c400;
  letter-spacing: 0.25em;
  font-size: 0.95rem;
  margin-top: 10px;
}

.auth-panel-single { width: min(460px, 100%); }
.auth-panel-title { margin-top: 0; font-size: 1.2rem; }

/* ━━━━━━━━━━━━━━━━  PORTAL HEADER  ━━━━━━━━━━━━━━━━ */
.portal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}
.portal-header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.portal-title { margin: 0; font-size: 1.5rem; font-weight: 900; }
.portal-sub { margin: 4px 0 0; color: var(--muted); font-size: 0.9rem; }

.state-summary-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 18px;
  padding: 18px 20px;
  box-shadow: var(--shadow);
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.summary-label {
  color: var(--muted);
  font-size: 0.8rem;
  font-weight: 700;
}

.summary-value {
  font-size: 1.2rem;
  font-weight: 900;
  margin-top: 4px;
}

.lists-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}

.list-card {
  display: block;
  text-decoration: none;
  color: var(--ink);
  background: linear-gradient(180deg, color-mix(in srgb, var(--card) 86%, #eef5ff), var(--card));
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 20px;
  box-shadow: var(--shadow);
  transition: transform 0.18s ease, border-color 0.18s ease;
}

.list-card:hover {
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--primary) 38%, var(--line));
}

.list-card-key {
  width: 34px;
  height: 34px;
  border-radius: 10px;
  background: linear-gradient(120deg, var(--primary), var(--primary-2));
  color: #fff;
  display: grid;
  place-items: center;
  font-weight: 800;
  margin-bottom: 14px;
}

.list-card h2 {
  margin: 0 0 8px;
  font-size: 1.15rem;
}

.list-card p {
  margin: 0 0 14px;
  color: var(--muted);
  line-height: 1.5;
}

.list-card-cta {
  font-weight: 800;
  color: var(--primary);
}

/* ━━━━━━━━━━━━━━━━  REGISTRATION CARD  ━━━━━━━━━━━━━━━━ */
.registration-card {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 20px;
  padding: 24px 28px;
  box-shadow: var(--shadow);
}

.reg-section-label {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--primary);
  margin: 0 0 10px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--line);
}

.reg-basic-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
  margin-bottom: 22px;
}

.transfer-grid {
  grid-template-columns: repeat(3, 1fr);
}

.inline-warning {
  margin: 0 0 16px;
  border: 1px solid #e4c17a;
  background: #fff5de;
  color: #8f5a00;
  border-radius: 12px;
  padding: 10px 12px;
  font-weight: 700;
}

.empty-table-row {
  text-align: center;
  color: var(--muted);
  padding: 20px 12px;
}

.transfer-table-card {
  margin-top: 18px;
}

.reg-field { display: flex; flex-direction: column; gap: 6px; }
.reg-label { color: var(--muted); font-size: 0.83rem; font-weight: 700; }

.reg-dynamic-strip {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(170px, 210px);
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 10px;
  margin-bottom: 22px;
  scrollbar-width: thin;
}

.reg-field-card {
  background: color-mix(in srgb, var(--card) 65%, var(--bg));
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 0;
}

.reg-field-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
}

.add-opt-btn {
  font-size: 0.74rem;
  font-weight: 700;
  color: var(--primary);
  background: none;
  border: 1px solid color-mix(in srgb, var(--primary) 40%, transparent);
  border-radius: 6px;
  padding: 2px 7px;
  cursor: pointer;
  white-space: nowrap;
  font-family: inherit;
}
.add-opt-btn:hover { background: color-mix(in srgb, var(--primary) 12%, transparent); }

.reg-select { height: 40px; }

.add-opt-row {
  display: flex;
  gap: 6px;
  align-items: center;
}
.add-opt-row input { height: 36px; font-size: 0.85rem; flex: 1; min-width: 0; }
.add-opt-row .btn { height: 36px; font-size: 0.82rem; padding: 0 10px; white-space: nowrap; flex-shrink: 0; }

.reg-notes {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 10px 12px;
  background: var(--card);
  color: var(--ink);
  resize: vertical;
  min-height: 80px;
  font: inherit;
  margin-bottom: 20px;
  box-sizing: border-box;
}
.reg-notes:focus { outline: none; border-color: #6ea4ff; box-shadow: 0 0 0 3px rgba(39, 122, 255, 0.15); }

.reg-actions { display: flex; justify-content: flex-end; }
.reg-submit { display: inline-flex; align-items: center; gap: 8px; }

/* ━━━━━━━━━━━━━━━━  MEMBERS TABLE CARD  ━━━━━━━━━━━━━━━━ */
.members-card {
  background: var(--card);
  border: 1px solid var(--line);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: var(--shadow);
}

.members-table { width: 100%; border-collapse: collapse; min-width: 700px; }

.members-table th {
  background: color-mix(in srgb, var(--bg) 60%, var(--card));
  padding: 11px 12px;
  border-bottom: 1.5px solid var(--line);
  font-size: 0.78rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  white-space: nowrap;
  color: var(--muted);
}

.members-table td {
  padding: 10px 12px;
  border-bottom: 1px solid var(--line);
  vertical-align: middle;
}

.member-row:last-child td { border-bottom: none; }
.member-row:hover td { background: color-mix(in srgb, var(--primary) 4%, var(--card)); }

.col-seq { width: 42px; text-align: center; color: var(--muted); font-size: 0.82rem; }
.uid-cell { font-family: monospace; font-size: 0.88rem; color: var(--muted); }
.name-cell strong { font-weight: 700; }
.notes-cell { max-width: 180px; font-size: 0.85rem; color: var(--muted); }
.date-cell { white-space: nowrap; color: var(--muted); font-size: 0.82rem; }

.table-actions {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: nowrap;
}

.table-actions form {
  margin: 0;
}

.btn-sm {
  height: 32px;
  padding: 0 10px;
  font-size: 0.8rem;
  border-radius: 8px;
}

.empty-state {
  text-align: center;
  padding: 64px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.empty-icon { font-size: 3rem; }

/* ━━━━━━━━━━━━━━━━  NAV LINK  ━━━━━━━━━━━━━━━━ */
.nav-link {
  text-decoration: none;
  color: var(--ink);
  font-weight: 700;
  padding: 7px 12px;
  border-radius: 10px;
  border: 1px solid transparent;
  font-size: 0.9rem;
}

.nav-link-active {
  background: color-mix(in srgb, var(--primary) 14%, transparent);
  border-color: color-mix(in srgb, var(--primary) 34%, transparent);
}

.nav-link:hover {
  background: color-mix(in srgb, var(--primary) 12%, transparent);
  border-color: color-mix(in srgb, var(--primary) 30%, transparent);
}

/* ━━━━━━━━━━━━━━━━  RESPONSIVE  ━━━━━━━━━━━━━━━━ */
@media (max-width: 920px) {
  .layout,
  .auth-grid,
  .form-grid {
    grid-template-columns: 1fr;
  }

  .topbar {
    align-items: flex-start;
    flex-direction: column;
  }

  .lang-form {
    width: 100%;
  }

  .section-head,
  .member-form-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .reg-basic-grid { grid-template-columns: 1fr 1fr; }
  .transfer-grid { grid-template-columns: 1fr 1fr; }
  .portal-header { flex-direction: column; align-items: flex-start; }
  .portal-header-actions { width: 100%; }
  .state-summary-card { flex-direction: column; align-items: flex-start; }
  .reg-actions { justify-content: stretch; }
  .reg-submit { width: 100%; }
}

@media (max-width: 560px) {
  .reg-basic-grid { grid-template-columns: 1fr; }
  .transfer-grid { grid-template-columns: 1fr; }
  .tnt-logo-badge-xl { width: 88px; height: 88px; border-radius: 24px; }
  .tnt-logo-text { font-size: 1.8rem; }
  .tnt-logo-title { font-size: 1.7rem; }
}
